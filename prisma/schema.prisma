generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum StaffRole {
  STAFF
  ADMIN
}

enum MembershipStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  EXPIRED
}

enum PersonStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum WebhookEventStatus {
  RECEIVED
  PROCESSED
  FAILED
}

model Club {
  id                 String              @id @default(uuid())
  name               String
  slug               String              @unique
  ghlLocationId      String?             @unique @map("ghl_location_id")
  maxCapacity        Int                 @default(100) @map("max_capacity")
  isActive           Boolean             @default(true) @map("is_active")
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")
  staff              Staff[]
  memberships        Membership[]
  persons            Person[]
  checkinEvents      CheckinEvent[]
  guestPassPurchases GuestPassPurchase[]

  @@map("clubs")
}

model Staff {
  id             String         @id @default(uuid())
  clubId         String         @map("club_id")
  email          String         @unique
  passwordHash   String         @map("password_hash")
  name           String
  role           StaffRole      @default(STAFF)
  isActive       Boolean        @default(true) @map("is_active")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")
  club           Club           @relation(fields: [clubId], references: [id], onDelete: Cascade)
  checkinEvents  CheckinEvent[]
  memberEditLogs MemberEditLog[]

  @@index([clubId])
  @@map("staff")
}

model Membership {
  id                     String              @id @default(uuid())
  clubId                 String              @map("club_id")
  membershipCode         String?             @map("membership_code")
  externalMembershipId   String?             @map("external_membership_id")
  externalCustomerId     String?             @map("external_customer_id")
  tier                   String              @default("unknown") @map("tier")
  maxMembers             Int                 @default(1) @map("max_members")
  paymentAmountCents     Int                 @default(0) @map("payment_amount_cents")
  paymentStatus          String              @default("paid") @map("payment_status")
  paymentData            Json?               @map("payment_data")
  stripePaymentIntentId  String?             @map("stripe_payment_intent_id")
  stripeSetupIntentId    String?             @map("stripe_setup_intent_id")
  guestPassesTotal       Int                 @default(0) @map("guest_passes_total")
  guestPassesUsed        Int                 @default(0) @map("guest_passes_used")
  source                 String              @default("ghl_signup") @map("source")
  ghlContactId           String?             @map("ghl_contact_id")
  addressStreet          String?             @map("address_street")
  addressCity            String?             @map("address_city")
  addressState           String?             @map("address_state")
  addressPostalCode      String?             @map("address_postal_code")
  addressCountry         String?             @map("address_country")
  submittedAt            DateTime?           @map("submitted_at")
  externalOrderId        String?             @map("external_order_id")
  signupIp               String?             @map("signup_ip")
  signupTimezone         String?             @map("signup_timezone")
  signupUrl              String?             @map("signup_url")
  emailVerified          Boolean             @default(false) @map("email_verified")
  phoneVerified          Boolean             @default(false) @map("phone_verified")
  status                 MembershipStatus    @default(ACTIVE)
  startsAt               DateTime?           @map("starts_at")
  endsAt                 DateTime?           @map("ends_at")
  createdAt              DateTime            @default(now()) @map("created_at")
  updatedAt              DateTime            @updatedAt @map("updated_at")
  club                   Club                @relation(fields: [clubId], references: [id], onDelete: Cascade)
  persons                Person[]
  checkinEvents          CheckinEvent[]
  guestPassPurchases     GuestPassPurchase[]

  @@unique([clubId, membershipCode])
  @@unique([clubId, externalMembershipId])
  @@unique([clubId, externalOrderId])
  @@index([clubId, status])
  @@index([clubId, submittedAt])
  @@map("memberships")
}

model Person {
  id                 String              @id @default(uuid())
  clubId             String              @map("club_id")
  membershipId       String              @map("membership_id")
  firstName          String              @map("first_name")
  lastName           String              @map("last_name")
  email              String?
  phone              String?
  ghlContactId       String?             @map("ghl_contact_id")
  age                Int?                @map("age")
  relationship       String              @default("self") @map("relationship")
  allergies          String?             @map("allergies")
  emergencyContactName  String?          @map("emergency_contact_name")
  emergencyContactPhone String?          @map("emergency_contact_phone")
  emergencyContactEmail String?          @map("emergency_contact_email")
  notes              String?             @map("notes")
  isPrimary          Boolean             @default(false) @map("is_primary")
  status             PersonStatus        @default(ACTIVE)
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")
  club               Club                @relation(fields: [clubId], references: [id], onDelete: Cascade)
  membership         Membership          @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  checkinEvents      CheckinEvent[]
  guestPassPurchases GuestPassPurchase[]

  @@unique([clubId, ghlContactId])
  @@index([clubId, email])
  @@index([clubId, phone])
  @@index([clubId, membershipId])
  @@map("persons")
}

model CheckinEvent {
  id                  String             @id @default(uuid())
  clubId              String             @map("club_id")
  personId            String             @map("person_id")
  membershipId        String?            @map("membership_id")
  guestPassPurchaseId String?            @map("guest_pass_purchase_id")
  staffId             String?            @map("staff_id")
  eventType           String             @default("check_in") @map("event_type")
  numGuests           Int                @default(0) @map("num_guests")
  guestPassMethod     String?            @map("guest_pass_method")
  source              String             @default("qr_form") @map("source")
  isActive            Boolean            @default(true) @map("is_active")
  checkedInAt         DateTime           @default(now()) @map("checked_in_at")
  signedOutAt         DateTime?          @map("signed_out_at")
  notes               String?
  createdAt           DateTime           @default(now()) @map("created_at")
  updatedAt           DateTime           @updatedAt @map("updated_at")
  club                Club               @relation(fields: [clubId], references: [id], onDelete: Cascade)
  person              Person             @relation(fields: [personId], references: [id], onDelete: Cascade)
  membership          Membership?        @relation(fields: [membershipId], references: [id], onDelete: SetNull)
  guestPassPurchase   GuestPassPurchase? @relation(fields: [guestPassPurchaseId], references: [id], onDelete: SetNull)
  staff               Staff?             @relation(fields: [staffId], references: [id], onDelete: SetNull)

  @@index([clubId, isActive])
  @@index([personId, checkedInAt])
  @@map("checkin_events")
}

model GuestPassPurchase {
  id                String         @id @default(uuid())
  clubId            String         @map("club_id")
  membershipId      String?        @map("membership_id")
  personId          String?        @map("person_id")
  code              String
  quantityPurchased Int            @default(1) @map("quantity_purchased")
  quantityUsed      Int            @default(0) @map("quantity_used")
  expiresAt         DateTime?      @map("expires_at")
  purchasedAt       DateTime       @default(now()) @map("purchased_at")
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")
  club              Club           @relation(fields: [clubId], references: [id], onDelete: Cascade)
  membership        Membership?    @relation(fields: [membershipId], references: [id], onDelete: SetNull)
  person            Person?        @relation(fields: [personId], references: [id], onDelete: SetNull)
  checkinEvents     CheckinEvent[]

  @@unique([clubId, code])
  @@index([clubId, membershipId])
  @@index([clubId, personId])
  @@map("guest_pass_purchases")
}

model WebhookEvent {
  id           String             @id @default(uuid())
  clubId       String?            @map("club_id")
  endpoint     String
  rawPayload   Json               @map("raw_payload")
  status       WebhookEventStatus @default(RECEIVED)
  errorMessage String?            @map("error_message")
  replayOfId   String?            @map("replay_of_id")
  receivedAt   DateTime           @default(now()) @map("received_at")
  processedAt  DateTime?          @map("processed_at")

  @@index([status, receivedAt])
  @@index([endpoint, receivedAt])
  @@map("webhook_events")
}

model MemberEditLog {
  id           String   @id @default(uuid())
  clubId       String   @map("club_id")
  staffId      String   @map("staff_id")
  targetType   String   @map("target_type")
  personId     String?  @map("person_id")
  membershipId String?  @map("membership_id")
  targetLabel  String   @map("target_label")
  changes      Json
  createdAt    DateTime @default(now()) @map("created_at")
  staff        Staff    @relation(fields: [staffId], references: [id])

  @@index([clubId, createdAt])
  @@map("member_edit_logs")
}
