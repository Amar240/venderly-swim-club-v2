PORT=3000

# Runtime surface:
# - pilot: public demo plus restricted, club-scoped staff application access.
# - demo: isolated public demo only, with no authenticated staff APIs.
# - full: existing Wedgewood production behavior.
APP_MODE=full

# Database split:
# - swimclub: production/App Runner only; never use for local development or tests.
# - swimclub_dev: local development only; persistent realistic data for npm run dev.
# - swimclub_test: integration tests only; npm run test:integration truncates this database.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/swimclub_dev?schema=public"
DATABASE_URL_TEST="postgresql://postgres:postgres@localhost:5432/swimclub_test?schema=public"

JWT_SECRET="replace-with-a-long-random-secret"
WEBHOOK_SECRET="replace-with-ghl-webhook-secret"
CORS_ORIGIN="*"
GHL_RETURN_URL=https://wedgewoodpool.com

# Public pilot retention. The current pilot contract is fixed at seven days.
DEMO_RETENTION_DAYS=7
DISABLE_DEMO_CLEANUP=false

# The sandbox App Runner service should also set these to true. APP_MODE=demo
# and APP_MODE=pilot already avoid starting them; these values provide defense in depth.
DISABLE_AUTO_SIGNOUT=false
DISABLE_EMAIL_DIGEST=false
DISABLE_WEBHOOK_CLEANUP=false

# Optional preview-only AI mapping fallback. Samples are masked before transmission.
AI_MAPPING_ENABLED=false
BEDROCK_REGION=us-east-2
BEDROCK_MODEL_ID=us.anthropic.claude-haiku-4-5-20251001-v1:0
